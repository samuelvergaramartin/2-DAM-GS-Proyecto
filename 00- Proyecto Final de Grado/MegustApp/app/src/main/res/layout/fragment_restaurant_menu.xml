<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    tools:context=".fragments.FragmentRestaurantMenu">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_gravity="center"
            android:src="@drawable/logo" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="150dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/menu"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:textColor="@color/accentAlt"
                    android:textAlignment="center"/>

                <View
                    android:layout_width="100dp"
                    android:layout_height="5dp"
                    android:background="@color/accentAlt"
                    android:layout_gravity="center"
                    android:layout_marginBottom="20dp"/>
            </LinearLayout>

            <ImageView
                android:id="@+id/imagen_editar_fragment_restaurant_menu"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:src="@drawable/edit_2"
                android:layout_marginTop="15dp"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

        <ListView
            android:id="@+id/listado_platos_fragment_restaurant_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp" />
    </LinearLayout>

</FrameLayout>