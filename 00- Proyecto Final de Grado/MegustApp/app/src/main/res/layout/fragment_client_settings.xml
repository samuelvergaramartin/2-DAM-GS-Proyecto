<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/colorPrimary"
    android:id="@+id/client_settings_fragment"
    tools:context=".fragments.ClientSettingsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/foto_perfil_fragment_client_settings"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            android:src="@drawable/logo" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/usuario_fragment_client_settings"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/textOnDark"
                android:textColorHint="@color/textOnDark"
                android:inputType="text"
                android:background="@drawable/edit_text"
                android:padding="10dp"
                android:textAlignment="center"
                android:layout_marginStart="15dp"/>

            <EditText
                android:id="@+id/correo_fragment_client_settings"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/textOnDark"
                android:textColorHint="@color/textOnDark"
                android:inputType="textEmailAddress"
                android:background="@drawable/edit_text"
                android:padding="10dp"
                android:textAlignment="center"
                android:layout_marginStart="15dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/clave_fragment_client_settings"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/textOnDark"
                android:textColorHint="@color/textOnDark"
                android:hint="Cambiar contraseña"
                android:inputType="textPassword"
                android:background="@drawable/edit_text"
                android:padding="10dp"
                android:textAlignment="center"
                android:layout_marginStart="15dp"/>

            <EditText
                android:id="@+id/telefono_fragment_client_settings"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/textOnDark"
                android:textColorHint="@color/textOnDark"
                android:inputType="phone"
                android:background="@drawable/edit_text"
                android:padding="10dp"
                android:textAlignment="center"
                android:layout_marginStart="15dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/ciudad_fragment_client_settings"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/textOnDark"
                android:textColorHint="@color/textOnDark"
                android:inputType="text"
                android:background="@drawable/edit_text"
                android:padding="10dp"
                android:textAlignment="center"
                android:layout_marginStart="15dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/boton_guardar_cambios_fragment_client_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guardar_cambios"
            android:textSize="18sp"
            android:layout_gravity="center"
            android:backgroundTint="@color/accent"
            android:textColor="@color/textSecondary"/>

    </LinearLayout>

</FrameLayout>