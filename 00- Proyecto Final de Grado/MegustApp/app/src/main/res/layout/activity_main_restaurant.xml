<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/restaurant_main_activity"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorPrimary"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar_activity_main_restaurant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
        style="@style/ThemeOverlay.AppCompat.Dark"
        app:titleTextColor="@color/colorPrimary"
        android:foregroundTint="@color/colorPrimary"
        android:background="@color/accent"
        app:title="@string/restaurante"
        android:elevation="4dp"/>

    <FrameLayout
        android:id="@+id/framelayout_activity_main_restaurant"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/navbar_activity_main_restaurant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accentAlt"
        app:itemTextColor="@color/black"
        app:itemIconTint="@color/black"
        app:menu="@menu/navbar_restaurant" />

</LinearLayout>